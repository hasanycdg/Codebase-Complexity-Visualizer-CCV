{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codebase Complexity Visualizer",
  "version": "0.1.0",
  "identifier": "com.ccv.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "corepack pnpm --filter @ccv/model build && corepack pnpm --filter @ccv/analyzer build && ../../scripts/build-native-analyzer-sidecar.sh debug && corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build && ../../scripts/build-native-analyzer-sidecar.sh release"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codebase Complexity Visualizer",
        "width": 1400,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["app"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "externalBin": ["binaries/ccv-analyzer"]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:ccv.db"]
    }
  }
}
